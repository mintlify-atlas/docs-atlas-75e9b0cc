  "keyFeatures": [
    "PPO-based reinforcement learning for biological neurons",
    "Real-time UDP communication with CL1 neural hardware",
    "Encoder-decoder architecture for neural stimulation and spike decoding",
    "Multiple DOOM scenarios with curriculum learning",
    "Dynamic feedback system with surprise-based scaling",
    "Ablation modes for validating neural contributions",
    "TensorBoard integration for training monitoring",
    "Checkpoint management for model persistence"
  ],
  "publicApiSurface": [
    "ppo_doom.py - Standalone PPO training script",
    "training_server.py --mode train - Start training server",
    "training_server.py --mode watch - Run inference with trained model",
    "cl1_neural_interface.py - CL1 hardware interface server",
    "PPOConfig - Main configuration dataclass",
    "EventFeedbackConfig - Feedback configuration",
    "udp_protocol.pack_stim_command() - Pack stimulation command",
    "udp_protocol.unpack_spike_data() - Unpack spike response",
    "udp_protocol.pack_feedback_command() - Pack feedback command"
  ]
